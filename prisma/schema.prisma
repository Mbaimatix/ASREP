// ASREP Africa — Prisma Database Schema
// Manages user accounts, RBAC roles, contact form logs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User Roles ───────────────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN  // Full system access: code, CMS, user management
  EDITOR       // Create, edit, publish all content; manage media
  AUTHOR       // Draft content; cannot publish without Editor approval
  VIEWER       // Read-only CMS access
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // bcrypt hashed
  name          String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relationships
  contactLogs   ContactLog[]

  @@index([email])
}

// ─── Contact Form Submissions ────────────────────────────────────────────────
model ContactLog {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  organisation String?
  subject      String
  message      String   @db.Text
  createdAt    DateTime @default(now())
  isRead       Boolean  @default(false)
  repliedBy    User?    @relation(fields: [repliedById], references: [id])
  repliedById  String?

  @@index([createdAt])
}

// ─── Newsletter Subscribers ───────────────────────────────────────────────────
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  subscribedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([email])
}

// ─── Volunteer Enquiries ──────────────────────────────────────────────────────
model VolunteerEnquiry {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  skills       String
  availability String
  message      String?  @db.Text
  createdAt    DateTime @default(now())
  isReviewed   Boolean  @default(false)

  @@index([createdAt])
}

// ─── Partner Enquiries ────────────────────────────────────────────────────────
model PartnerEnquiry {
  id               String   @id @default(cuid())
  organisationName String
  contactName      String
  email            String
  partnerType      String   // institutional | funding | corporate
  message          String   @db.Text
  createdAt        DateTime @default(now())
  isReviewed       Boolean  @default(false)

  @@index([createdAt])
}

// ─── Donation Records ─────────────────────────────────────────────────────────
model Donation {
  id                     String   @id @default(cuid())
  orderTrackingId        String   @unique
  orderMerchantReference String
  status                 String   // COMPLETED | FAILED | INVALID | REVERSED
  amount                 Float
  currency               String   @default("KES")
  paymentMethod          String   @default("")
  donorName              String   @default("")
  donorEmail             String   @default("")
  programme              String   @default("General")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}
