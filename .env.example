# ASREP Africa — Environment Variable Reference
# Copy this file to .env.local and fill in all values before running locally.
# NEVER commit .env.local — it is gitignored.

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=                  # Canonical site URL, e.g. https://asrepafrica.org

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=                          # Same as NEXT_PUBLIC_SITE_URL (required by NextAuth v4)
NEXTAUTH_SECRET=                       # Random 32-byte hex — generate: openssl rand -hex 32
AUTH_SECRET=                           # NextAuth v5 alias for NEXTAUTH_SECRET (set both)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=                          # PostgreSQL connection string (Neon, Supabase, etc.)

# ─── Pesapal Payment Gateway ──────────────────────────────────────────────────
PESAPAL_ENV=                           # "sandbox" for testing | "production" when live
PESAPAL_CONSUMER_KEY=                  # From Pesapal dashboard → API credentials
PESAPAL_CONSUMER_SECRET=               # From Pesapal dashboard → API credentials
PESAPAL_IPN_URL=                       # Full URL of IPN handler: https://yourdomain.com/api/donate/pesapal/ipn
PESAPAL_IPN_SECRET=                    # Random secret appended as ?token= to the IPN URL — generate: openssl rand -hex 32

# ─── GitHub OAuth (Decap CMS) ─────────────────────────────────────────────────
GITHUB_OAUTH_CLIENT_ID=                # From GitHub → Settings → Developer settings → OAuth Apps
GITHUB_OAUTH_CLIENT_SECRET=            # From GitHub → Settings → Developer settings → OAuth Apps

# ─── Email (Contact & Newsletter forms) ───────────────────────────────────────
EMAIL_FROM=                            # Sender address shown in outgoing emails
EMAIL_TO=                              # Recipient address for contact form submissions
EMAIL_SERVER_HOST=                     # SMTP hostname, e.g. smtp.gmail.com
EMAIL_SERVER_PORT=                     # SMTP port, e.g. 587
EMAIL_SERVER_USER=                     # SMTP login username
EMAIL_SERVER_PASSWORD=                 # SMTP password or app password

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=         # Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX

# ─── Error Monitoring ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                # Sentry DSN from sentry.io → Project → Settings → Client Keys

# ─── Rate Limiting (Upstash Redis) — optional but recommended ─────────────────
UPSTASH_REDIS_REST_URL=                # From Upstash console → Redis → REST API
UPSTASH_REDIS_REST_TOKEN=              # From Upstash console → Redis → REST API
